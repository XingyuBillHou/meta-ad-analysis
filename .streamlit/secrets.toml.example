# 复制为 secrets.toml 用于本地测试，或在 Streamlit Cloud 控制台粘贴同等内容。
# Cloud 路径：App → Settings → Secrets

[llm]
# 可选：预填大模型配置（私有团队部署时使用；公开应用建议让用户在侧边栏自行填写）
# api_key = "sk-xxxxxxxx"
# provider = "OpenAI"
# base_url = "https://api.openai.com/v1"
# model = "gpt-4o-mini"

[email]
# SMTP 发信配置（Gmail 需使用应用专用密码）
# smtp_host = "smtp.gmail.com"
# smtp_port = "587"
# smtp_user = "your@gmail.com"
# smtp_password = "your-app-password"
# from_addr = "your@gmail.com"
# from_name = "跨境电商广告分析报告"
# use_tls = "true"
# default_recipients = "boss@company.com, team@company.com"
